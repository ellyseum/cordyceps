{
  "name": "@ellyseum/cordyceps",
  "version": "0.3.4",
  "description": "Local-first agent harness — spawns and drives PTY-based CLI coding agents via a JSON-RPC 2.0 control plane, with a service bus and plugin architecture.",
  "type": "module",
  "bin": {
    "cordy": "./dist/cli/shell.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "scripts": {
    "build": "tsc && ([ -f dist/cli/shell.js ] && chmod +x dist/cli/shell.js || true)",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "aider",
    "agent",
    "harness",
    "pty",
    "orchestration",
    "json-rpc",
    "websocket"
  ],
  "author": {
    "name": "Ellyseum",
    "email": "jocelyn@ellyseum.dev"
  },
  "license": "MIT",
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
