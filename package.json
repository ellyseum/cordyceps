{
  "name": "@ellyseum/cordyceps",
  "version": "0.5.4",
  "description": "Local-first agent harness — spawns and drives PTY-based CLI coding agents via a JSON-RPC 2.0 control plane, with a service bus and plugin architecture.",
  "type": "module",
  "bin": {
    "cordy": "./dist/cli/shell.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20 || ^22 || ^24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-pty"
    ]
  },
  "scripts": {
    "build": "tsc && node -e \"try{require('fs').chmodSync('dist/cli/shell.js',0o755)}catch{}\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "aider",
    "agent",
    "harness",
    "pty",
    "orchestration",
    "json-rpc",
    "websocket",
    "ai",
    "llm",
    "cli"
  ],
  "author": {
    "name": "Jocelyn Ellyse",
    "email": "jocelyn@ellyseum.dev",
    "url": "https://github.com/ellyseum"
  },
  "license": "MIT",
  "homepage": "https://github.com/ellyseum/cordyceps#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ellyseum/cordyceps.git"
  },
  "bugs": {
    "url": "https://github.com/ellyseum/cordyceps/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "node-pty": "^1.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
